{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "GitHub Copilot agent hooks configuration. Consumed by the CI workflow (.github/workflows/copilot-hooks.yml) and any compatible Copilot Extension runner. Events mirror the Claude Code hook model so automation behaviour is consistent across both platforms.",
  "version": "1.0.0",
  "hooks": {
    "PostToolUse": [
      {
        "_comment": "Scan every Write/Edit for agent handoff signal phrases and route to the next agent.",
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .github/hooks/on_write.ps1",
            "workingDirectory": "${workspaceRoot}"
          }
        ]
      },
      {
        "_comment": "When project_state.md is written with ✅ DONE, output the Definition-of-Done checklist.",
        "matcher": "Write",
        "filePattern": "**/*project_state.md",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .github/hooks/on_task_complete.ps1",
            "workingDirectory": "${workspaceRoot}"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "_comment": "Remind the agent to sync state if active tasks remain open.",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .github/hooks/on_stop.ps1",
            "workingDirectory": "${workspaceRoot}"
          }
        ]
      }
    ]
  },
  "signalPhrases": {
    "_comment": "Exact strings the hooks scan for. Do NOT paraphrase these in agent responses.",
    "interAgent": [
      "Handing off to @codeReviewer",
      "Handing off to @qualityGuard",
      "Handing off to @devOps",
      "Quality gate cleared",
      "Returning to @techLead",
      "Cleared for implementation",
      "SECURITY FAIL:"
    ],
    "intraAgent": [
      "Observability design complete",
      "Reliability design complete",
      "Resilience patterns complete",
      "Dependency audit passed",
      "Integration tests complete",
      "Load tests complete",
      "Pipeline configured",
      "Environment promotion complete",
      "Change analysis complete. Activating impact_assessment.",
      "Impact assessment complete. Delegating to @"
    ]
  },
  "sharedState": {
    "projectState": ".github/shared/project_state.md",
    "standards": ".github/shared/standards.md",
    "architectureLog": ".github/shared/architecture_log.md"
  }
}
